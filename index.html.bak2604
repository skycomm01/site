              <!-- Vase body -->
              <path d="M150 120 Q150 100 170 100 H230 Q250 100 250 120 V160 Q280 200 280 260 Q280 360 240 410 H160 Q120 360 120 260 Q120 200 150 160 Z"
                    fill="#0e1118" stroke="url(#vg)" stroke-width="1.5"/>
