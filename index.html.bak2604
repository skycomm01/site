<script>
/* ==========================================================
   TAB TOGGLE
   ========================================================== */
const tabs = {
  b2b: document.getElementById('tab-b2b'),
  shop: document.getElementById('tab-shop'),
};
const pages = {
  b2b: document.getElementById('page-b2b'),
  shop: document.getElementById('page-shop'),
};
const pill = document.getElementById('togglePill');
const root = document.documentElement;

const palettes = {
  b2b:  {a1:'#22d3ee', a2:'#6366f1', a3:'#a855f7', glow:'#3b82f6'},
  shop: {a1:'#ff7a59', a2:'#ff4d8d', a3:'#e040c2', glow:'#ff6b88'},
};

function applyPalette(mode){
  const p = palettes[mode];
  root.style.setProperty('--a1', p.a1);
  root.style.setProperty('--a2', p.a2);
  root.style.setProperty('--a3', p.a3);
  root.style.setProperty('--aglow', p.glow);
}

function movePill(mode){
  const btn = tabs[mode];
  const tRect = btn.parentElement.getBoundingClientRect();
  const bRect = btn.getBoundingClientRect();
  pill.style.left = (bRect.left - tRect.left) + 'px';
  pill.style.width = bRect.width + 'px';
}

function setMode(mode, opts = {}){
  const other = mode === 'b2b' ? 'shop' : 'b2b';

  tabs[mode].setAttribute('aria-selected','true');
  tabs[other].setAttribute('aria-selected','false');

  // crossfade
  const showPage = pages[mode], hidePage = pages[other];
  hidePage.classList.remove('in');
  setTimeout(()=>{
    hidePage.classList.remove('active');
    hidePage.setAttribute('hidden','');
    showPage.removeAttribute('hidden');
    showPage.classList.add('active');
    requestAnimationFrame(()=> showPage.classList.add('in'));
    // re-trigger reveals inside the now-visible page
    queueMicrotask(()=> {
      showPage.querySelectorAll('.reveal').forEach(el=>{
        el.classList.remove('in');
      });
      observeReveals(showPage);
    });
    // scroll to top of viewport on mode switch (smooth)
    if (!opts.silent){
      window.scrollTo({top:0, behavior:'smooth'});
    }
  }, 220);

  applyPalette(mode);
  movePill(mode);

  // update hash without jumping
  const hash = '#' + mode;
  if (location.hash !== hash){
    history.replaceState(null, '', hash);
  }
}

tabs.b2b.addEventListener('click', ()=> setMode('b2b'));
tabs.shop.addEventListener('click', ()=> setMode('shop'));

// Keyboard arrows on toggle
[tabs.b2b, tabs.shop].forEach(btn=>{
  btn.addEventListener('keydown', e=>{
    if (e.key === 'ArrowRight' || e.key === 'ArrowLeft'){
      e.preventDefault();
      const next = btn === tabs.b2b ? 'shop' : 'b2b';
      const prev = btn === tabs.b2b ? 'shop' : 'b2b';
      const target = e.key === 'ArrowRight' ? next : prev;
      setMode(target);
      tabs[target].focus();
    }
  });
});

// Footer cross-links
document.querySelectorAll('[data-go]').forEach(a=>{
  a.addEventListener('click', ()=> {
    const m = a.getAttribute('data-go');
    if (m && tabs[m]) setMode(m);
  });
});

// Init from hash
function initFromHash(){
  const m = location.hash.replace('#','');
  if (m === 'shop' || m === 'b2b'){
    setMode(m, {silent:true});
  } else {
    // default b2b — just set the pill
    applyPalette('b2b');
    movePill('b2b');
  }
}
window.addEventListener('hashchange', initFromHash);
window.addEventListener('resize', ()=>{
  const active = tabs.b2b.getAttribute('aria-selected') === 'true' ? 'b2b' : 'shop';
  movePill(active);
});

/* ==========================================================
   SCROLL REVEAL
   ========================================================== */
let io = null;
function observeReveals(scope){
  const els = (scope || document).querySelectorAll('.reveal');
  if (!io){
    io = new IntersectionObserver(entries=>{
      entries.forEach(en=>{
        if (en.isIntersecting){
          en.target.classList.add('in');
          io.unobserve(en.target);
        }
      });
    }, {rootMargin:'0px 0px -8% 0px', threshold:.05});
  }
  els.forEach(el => {
    if (!el.classList.contains('in')) io.observe(el);
  });
}

/* ==========================================================
   CARD HOVER SPOTLIGHT
   ========================================================== */
function bindSpotlights(){
  document.querySelectorAll('.card, .product, .kat, [data-tilt]').forEach(c=>{
    if (c.__spotBound) return;
    c.__spotBound = true;
    c.addEventListener('mousemove', e=>{
      const r = c.getBoundingClientRect();
      c.style.setProperty('--mx', ((e.clientX - r.left) / r.width * 100) + '%');
      c.style.setProperty('--my', ((e.clientY - r.top) / r.height * 100) + '%');
    });
  });
}

/* ==========================================================
   BOOT
   ========================================================== */
window.addEventListener('load', ()=>{
  // Need fonts before measuring pill
  if (document.fonts && document.fonts.ready){
    document.fonts.ready.then(()=> { initFromHash(); });
  } else {
    initFromHash();
  }
  observeReveals();
  bindSpotlights();
});

// Initial pill placement (pre-fonts) so it doesn't flash at 0
requestAnimationFrame(()=>{
  applyPalette('b2b');
  movePill('b2b');
  observeReveals();
  bindSpotlights();
});
</script>

</body>
</html>
